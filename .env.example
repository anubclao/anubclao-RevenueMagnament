# Frontend — .env.local (NO commitear, usado solo en dev local)
# En Hostinger estas mismas variables se configuran en
# hPanel → Advanced → Node.js → Variables de entorno
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── MySQL (requerido en producción) ──────────────────────────────
# El app NO arranca sin estas en producción.
# Defaults de dev local: localhost / root / sin password / DB "bora_bora_rm"
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=bora_bora_rm

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=production
