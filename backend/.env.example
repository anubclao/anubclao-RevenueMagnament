# Copiar a .env y rellenar. NO commitear .env real.

# --- App ---
APP_ENV=development
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000

# --- DB (producción) ---
# Obtener de Hostinger hPanel → Bases de datos MySQL
DATABASE_URL=mysql+asyncmy://bora_user:CHANGE_ME@localhost:3306/bora_bora_rm?charset=utf8mb4

# --- DB (dev local) ---
DATABASE_URL_LOCAL=sqlite+aiosqlite:///./bora_bora_rm.db

# --- Upload limits ---
MAX_UPLOAD_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.xlsx
